# Chilly Phone 前端环境变量示例
# 复制此文件为 .env.production 填入实际值

# Web Push 服务器 URL (Cloudflare Worker 部署后获得)
# 部署步骤见 worker/README.md
VITE_PUSH_SERVER_URL=https://chilly-phone-push.YOUR-SUBDOMAIN.workers.dev

# WAQI (世界空气质量指数) API token
# 在 https://aqicn.org/data-platform/token/ 申请免费 token
# 留空则 AQI 卡片显示 "AQI --"
VITE_WAQI_TOKEN=your_waqi_token_here
