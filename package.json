    "tone": "^15.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/compiler-sfc": "^3.5.26",
    "autoprefixer": "^10.4.23",
    "esbuild-plugin-vue3": "^0.5.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.113.0"
