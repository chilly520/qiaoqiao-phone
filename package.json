{
  "name": "qiaqiao-phone",
  "private": true,
  "version": "1.10.223",
  "type": "module",
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-esbuild.mjs && node scripts/copy-functions.js",
    "build:vite": "vite build && node scripts/copy-functions.js",
